---
// Home page. A file in `src/pages/` becomes a route — this one is the site root `/`.
// It composes the section components in order inside the shared BaseLayout; the
// design is a single scrolling page with no navigation.

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import About from '../components/About.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Work from '../components/Work.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Rashmil Panchani">
    <Header />
    <main>
        <About />
        <Education />
        <Projects />
        <Skills />
        <Work />
    </main>
    <Footer />
</BaseLayout>
