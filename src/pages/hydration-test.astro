---
// Test-only page that proves React hydration works end to end. The smoke test
// asserts this page ships a real React chunk in the build output.
//
// Astro turns each file in `src/pages/` into a route — EXCEPT files whose name
// starts with `_`, which are excluded from routing. So this is named
// `hydration-test.astro` (built URL: /hydration-test/), not `_hydration-test.astro`.
//
// `client:load` is the key directive: without a `client:*` directive Astro ships
// zero JS for a component (static HTML only). `client:load` tells Astro to hydrate
// it in the browser as soon as the page loads, which is what the smoke test checks.

import BaseLayout from '../layouts/BaseLayout.astro';
import HydrationCheck from '../../tests/__fixtures__/HydrationCheck.tsx';
---

<BaseLayout title="Hydration test">
    <HydrationCheck client:load />
</BaseLayout>
