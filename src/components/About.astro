---
// About section: polaroid profile photo with logo icons + a terminal-style card.
//
// `<Image>` (from astro:assets) optimizes a local image at build time — it emits a
// resized, modern-format file and the right width/height to avoid layout shift.
// The image is `import`ed (not referenced by string) so Astro can process it.

import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import profilePic from '../assets/profile.jpeg';

const aboutEntry = await getEntry('about', 'about');
if (!aboutEntry) throw new Error('about.yaml missing');
const { description, description_header } = aboutEntry.data;

const polaroidIcons = ['logos:python', 'logos:react', 'logos:pytorch', 'logos:tensorflow'];
---

<section id="about" class="section-surface overflow-hidden px-4 pb-16">
    <h2 class="section-title section-title-dark">About me</h2>
    <div class="mx-auto flex max-w-5xl flex-col items-center gap-10 md:flex-row md:items-start">
        <div class="text-center">
            <div class="polaroid">
                {
                    /* `widths` generates a srcset (250w + 500w) so retina screens get the sharper file. */
                }
                <Image
                    src={profilePic}
                    alt="Rashmil Panchani"
                    width={250}
                    widths={[250, 500]}
                    class="mx-auto block max-w-[250px]"
                />
                <div class="mt-4 flex justify-center gap-4">
                    {
                        polaroidIcons.map((icon) => (
                            <Icon name={icon} class="size-10" aria-hidden="true" />
                        ))
                    }
                </div>
            </div>
        </div>
        <div class="w-full max-w-xl">
            <div class="terminal-card">
                <div class="terminal-card-header" aria-hidden="true">
                    <span class="terminal-dot bg-[#ff5f57]"></span>
                    <span class="terminal-dot bg-[#febc2e]"></span>
                    <span class="terminal-dot bg-[#28c840]"></span>
                </div>
                <div class="px-6 py-6 text-lg leading-loose">
                    <p class="wave mb-4">
                        {description_header}
                        <span role="img" aria-label="waving hand">👋</span> :)
                    </p>
                    <p>{description}</p>
                </div>
            </div>
        </div>
    </div>
</section>
