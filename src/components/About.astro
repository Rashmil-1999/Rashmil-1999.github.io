---
// src/components/About.astro
// Phase 3 Plan 03-03 Task 1: filled per RESEARCH.md Pattern 3 + PATTERNS.md About port.
// Singleton read via getEntry('about', 'about') — about.yaml top-level key is `about:`.
// Consumes .social-icon, .btn-primary, .text-primary, .profile-pic, .subheading, .lead,
// .resume-section, .resume-section-content from src/styles/global.css (Plan 03-02).

import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import profileImage from '../assets/profile.jpg';

const aboutEntry = await getEntry('about', 'about');
if (!aboutEntry) throw new Error('about.yaml missing — was Phase 2 completed?');
const about = aboutEntry.data;
const fullName = `${about.first_name} ${about.last_name}`;
const mailtoHref = `mailto:${about.email}`;
// D-27: site-root-relative path; about.resume_download is "Rashmil_Panchani.pdf" in public/.
const resumeHref = `/${about.resume_download}`;
---

<section id="about" class="resume-section">
    <div class="resume-section-content">
        {/* Mobile-only profile photo per D-25 + D-11 — sidebar carries it at >= md */}
        <div class="text-center md:hidden">
            <Image
                src={profileImage}
                alt={fullName}
                class="profile-pic mx-auto mb-4 rounded-full"
                width={200}
                height={225}
            />
        </div>

        <h1 class="mb-0">
            {about.first_name}{' '}
            <span class="text-primary">{about.last_name}</span>
            {
                /* Phase 1 D-12 + smoke assertion #5: keep Tailwind marker `text-[#abc123]`
                detectable in dist/_astro/*.css without polluting visual output. */
            }
            <span aria-hidden="true" class="sr-only text-[#abc123]"></span>
        </h1>

        <div class="subheading mb-5">
            <p class="mb-3">{about.current_status}</p>
            <p class="lead mb-0">{about.contact_message}</p>
            <a href={mailtoHref}>{about.email}</a>
        </div>

        <p class="lead mb-5">{about.description}</p>

        <div class="flex flex-wrap items-center gap-4">
            {/* Social row — D-26 ARIA + new-tab announcement */}
            <div class="flex gap-3">
                {
                    about.social.map((handle) => (
                        <a
                            href={handle.url}
                            aria-label={handle.name}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="social-icon"
                        >
                            <Icon name={handle.icon} aria-hidden="true" class="size-6" />
                            <span class="sr-only">(opens in new tab)</span>
                        </a>
                    ))
                }
            </div>

            {/* Resume download CTA — D-27 copy "Download Resume" (no icon-only) */}
            <a href={resumeHref} download class="btn-primary"> Download Resume </a>
        </div>
    </div>
</section>
<hr class="m-0 border-black/10" />
