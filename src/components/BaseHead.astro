---
// Contents of <head>, kept minimal: charset, viewport, title, favicon.
//
// In an .astro file the code between the `---` fences ("frontmatter") runs at build
// time on the server. The `Props` interface types the data a parent passes in, and
// `Astro.props` is how you read it.

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<link rel="icon" href="/favicon.svg" />
{
    /* No Google Fonts preconnect: fonts are self-hosted via @fontsource, so the
       browser never reaches out to a third-party font host. */
}
