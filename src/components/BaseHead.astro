---
// src/components/BaseHead.astro
// CONTEXT.md D-13: minimal head — charset, viewport, title, favicon, two font hints.
// Phase 4 SEO-01 expands this with the social/meta tags.
// Phase 3 STYLE-05 adds the font stylesheet link.

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<link rel="icon" href="/favicon.svg" />
{
    /* D-36: Google Fonts preconnects removed — fonts self-hosted via @fontsource/* starting in Plan 03-02 */
}
