---
// Projects section: clickable cards that open a modal carousel.
//
// The card/modal UI is a React island (ProjectsGallery), but all the heavy lifting
// happens here in the build-time frontmatter so the island ships only plain,
// serializable data:
//   - getImage() optimizes each cover/alternate image and returns a URL string.
//   - renderIcon() turns each Iconify id into an SVG string using the locally
//     installed @iconify-json sets — no icons are fetched at runtime in the browser.
// Props passed to a `client:*` island must be JSON-serializable, which is why we
// pre-resolve images and icons to strings rather than passing components.

import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import { getIconData, iconToSVG, iconToHTML, replaceIDs } from '@iconify/utils';
import { icons as devicon } from '@iconify-json/devicon';
import { icons as logos } from '@iconify-json/logos';
import { icons as lucide } from '@iconify-json/lucide';
import { icons as simpleIcons } from '@iconify-json/simple-icons';
import ProjectsGallery from './ProjectsGallery.tsx';
import type { GalleryProject } from './ProjectsGallery.tsx';

const iconSets = {
    devicon,
    logos,
    lucide,
    'simple-icons': simpleIcons,
} as const;

function renderIcon(id: string): string {
    const [prefix, name] = id.split(':');
    const set = iconSets[prefix as keyof typeof iconSets];
    if (!set) throw new Error(`Unknown icon set in "${id}"`);
    const data = getIconData(set, name ?? '');
    if (!data) throw new Error(`Unknown icon "${id}"`);
    const svg = iconToSVG(data, { height: 'auto' });
    return iconToHTML(replaceIDs(svg.body), svg.attributes);
}

const entries = await getCollection('projects', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
);
entries.sort((a, b) => a.data.order - b.data.order);

const projects: GalleryProject[] = await Promise.all(
    entries.map(async (entry) => {
        const sources = [entry.data.cover, ...(entry.data.alternates ?? [])];
        const images = await Promise.all(
            sources.map(async (src) => (await getImage({ src, width: 1000 })).src),
        );
        return {
            title: entry.data.title,
            startDate: entry.data.start_date,
            description: entry.body?.trim() ?? '',
            url: entry.data.url,
            images,
            tech: entry.data.tech_stack.map((t) => ({ name: t.name, svg: renderIcon(t.icon) })),
        };
    }),
);
---

<section id="projects" class="section-alt px-4 pb-16">
    <h2 class="section-title">Projects</h2>
    <ProjectsGallery projects={projects} client:visible />
</section>
