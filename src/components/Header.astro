---
// Hero section: laptop icon, name, rotating titles, theme switch, resume button.
//
// Frontmatter (this `---` block) runs at build time. `getEntry('about', 'about')`
// reads the single "about" entry from the Content Collections defined in
// content.config.ts — fully typed, so `aboutEntry.data` is autocompleted/checked.
// `<Icon>` (astro-icon) renders an Iconify SVG at build; `<HeroWidgets client:load>`
// is a React island hydrated in the browser (the typewriter + theme toggle).

import { getEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import HeroWidgets from './HeroWidgets.tsx';

const aboutEntry = await getEntry('about', 'about');
if (!aboutEntry) throw new Error('about.yaml missing');
const { first_name, last_name, titles, resume_download } = aboutEntry.data;
const name = `${first_name} ${last_name}`;
---

<header id="home" class="hero">
    <div>
        <Icon
            name="lucide:laptop"
            class="mx-auto size-32 text-(--hero-text) opacity-85"
            aria-hidden="true"
        />
        <h1 class="hero-name mb-4">{name}</h1>
        <HeroWidgets titles={[...titles]} client:load />
        <p class="mt-10">
            <a
                href={`/${resume_download}`}
                download
                class="title-styles inline-flex items-center gap-2"
            >
                <Icon name="lucide:download" class="size-6" aria-hidden="true" />
                Resume
            </a>
        </p>
    </div>
</header>
