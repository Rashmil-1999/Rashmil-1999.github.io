---
// Education section: a vertical timeline ending in a "diploma scroll" cap.
//
// `getCollection('education')` returns every entry in the collection; the filter
// hides drafts in production but shows them in dev. Each Markdown entry's body is
// turned into a renderable `<Content />` component by `render(entry)` — that's how
// you drop a collection's prose into the page. We pre-render them in `Promise.all`
// since `render` is async and can't be awaited inside the JSX map below.

import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

const entries = await getCollection('education', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
);
entries.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
    entries.map(async (entry) => ({
        entry,
        Content: (await render(entry)).Content,
    })),
);
---

<section id="education" class="section-alt px-4 pb-16">
    <h2 class="section-title">Education</h2>
    <ol role="list" class="timeline mx-auto max-w-3xl lg:max-w-4xl">
        {
            rendered.map(({ entry, Content }) => (
                <li class="relative mb-12">
                    <span class="timeline-node" aria-hidden="true">
                        <Icon name="lucide:graduation-cap" class="size-6" />
                    </span>
                    <div class="timeline-card">
                        <h3 class="text-xl font-bold">{entry.data.degree}</h3>
                        <p class="mb-1 text-sm">{entry.data.graduated}</p>
                        <p class="mb-2 text-lg">{entry.data.name}</p>
                        {entry.data.score && <p class="mb-2 text-sm">{entry.data.score}</p>}
                        <div class="text-sm">
                            <Content />
                        </div>
                    </div>
                </li>
            ))
        }
        <li class="relative">
            <span class="timeline-node" aria-hidden="true">
                <Icon name="lucide:scroll" class="size-6" />
            </span>
            <span class="sr-only">End of education timeline</span>
        </li>
    </ol>
</section>
