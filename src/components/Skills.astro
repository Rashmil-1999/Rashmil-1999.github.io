---
// src/components/Skills.astro
// Phase 3 Plan 03-03 Task 2: filled per RESEARCH.md Pattern 4 + PATTERNS.md Skills port.
// Singleton read via getEntry('skills', 'skills') — skills.yaml top-level key is `skills:`.
// Consumes .subheading, .resume-section, .resume-section-content from global.css (Plan 03-02).
// Per D-21, astro-icon fails the build loudly on unknown Iconify ids — no runtime fallback.

import { getEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';

const skillsEntry = await getEntry('skills', 'skills');
if (!skillsEntry) throw new Error('skills.yaml missing');
// Spread because Zod-validated readonly array under noUncheckedIndexedAccess.
const categories = [...skillsEntry.data.categories].sort((a, b) => a.order - b.order);
---

<section id="skills" class="resume-section">
    <div class="resume-section-content">
        <h2 class="mb-5">Skills</h2>
        {
            categories.map((category) => (
                <div class="mb-5">
                    <div class="subheading mb-3">{category.name}</div>
                    <ul role="list" class="dev-icons flex flex-wrap gap-4">
                        {category.items.map((item) => (
                            <li class="flex flex-col items-center">
                                <Icon name={item.icon} aria-hidden="true" class="size-6" />
                                <span class="mt-1 text-xs">{item.name}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            ))
        }
    </div>
</section>
<hr class="m-0 border-black/10" />
