---
// src/components/Skills.astro
// Live-site Skills port: centered categories of large colored Devicon icons
// with name labels and divider rules between categories (recovered Skills.jsx).
// Per D-21, astro-icon fails the build loudly on unknown Iconify ids.

import { getEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';

const skillsEntry = await getEntry('skills', 'skills');
if (!skillsEntry) throw new Error('skills.yaml missing');
// Spread because Zod-validated readonly array under noUncheckedIndexedAccess.
const categories = [...skillsEntry.data.categories].sort((a, b) => a.order - b.order);
---

<section id="skills" class="section-surface px-4 pb-16">
    <h2 class="section-title section-title-dark">Skills</h2>
    {
        categories.map((category, i) => (
            <div class="mx-auto max-w-4xl text-center">
                <h3 class="mb-6 text-lg font-bold">{category.name}</h3>
                <ul
                    role="list"
                    class="mb-8 flex flex-wrap items-end justify-center gap-x-8 gap-y-6"
                >
                    {category.items.map((item) => (
                        <li class="flex flex-col items-center">
                            <Icon name={item.icon} aria-hidden="true" class="size-12" />
                            <span class="mt-2 text-xs">{item.name}</span>
                        </li>
                    ))}
                </ul>
                {i < categories.length - 1 && <hr class="mx-auto mb-8 w-4/5 border-black/20" />}
            </div>
        ))
    }
</section>
