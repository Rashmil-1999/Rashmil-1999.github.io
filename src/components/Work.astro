---
// src/components/Work.astro
// Phase 3 Plan 03-04: filled per PATTERNS.md Work Astro port — same skeleton
// as Education.astro with field swaps (title/company/duration; no score field).
// CONTEXT.md D-23 + Phase 2 D-24: canonical id="work" and heading "Work".

import { getCollection, render } from 'astro:content';

const entries = await getCollection('work', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
);
entries.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
    entries.map(async (entry) => ({
        entry,
        Content: (await render(entry)).Content,
    })),
);
---

<section id="work" class="resume-section">
    <div class="resume-section-content">
        <h2 class="mb-5">Work</h2>
        {
            rendered.map(({ entry, Content }, id) => (
                <div
                    class={
                        id === rendered.length - 1
                            ? 'flex flex-col md:flex-row md:justify-between'
                            : 'mb-5 flex flex-col md:flex-row md:justify-between'
                    }
                >
                    <div class="flex-grow">
                        <h3 class="mb-0">{entry.data.title}</h3>
                        <div class="subheading mb-3">{entry.data.company}</div>
                        <Content />
                    </div>
                    <div class="flex-shrink-0">
                        <span class="text-muted">{entry.data.duration}</span>
                    </div>
                </div>
            ))
        }
    </div>
</section>
<hr class="m-0 border-black/10" />
