---
// Experience section: a vertical timeline (icon nodes, main-tech badges, soft tech
// chips, hourglass "career start" cap). Static HTML — no client JS ships.
//
// Same pattern as Education.astro: `getCollection` loads the entries, and
// `render(entry)` turns each Markdown body into a `<Content />` component. The
// async renders are resolved up front with `Promise.all` so the JSX can stay sync.

import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

const entries = await getCollection('work', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
);
entries.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
    entries.map(async (entry) => ({
        entry,
        Content: (await render(entry)).Content,
    })),
);
---

<section id="work" class="section-alt px-4 pb-16">
    <h2 class="section-title">Experience</h2>
    <ol role="list" class="timeline mx-auto max-w-3xl lg:max-w-4xl">
        {
            rendered.map(({ entry, Content }) => (
                <li class="relative mb-12">
                    <span class="timeline-node" aria-hidden="true">
                        {/* One consistent icon down the rail (the per-entry `icon`
                            field stays in the data but is no longer used here). */}
                        <Icon name="lucide:briefcase" class="size-6" />
                    </span>
                    <div class="timeline-card">
                        {entry.data.main_tech.length > 0 && (
                            <ul role="list" class="mb-3 flex flex-wrap gap-2">
                                {entry.data.main_tech.map((tech) => (
                                    <li class="main-badge">{tech}</li>
                                ))}
                            </ul>
                        )}
                        <h3 class="text-xl font-bold">{entry.data.title}</h3>
                        <p class="mb-1 text-sm">{entry.data.duration}</p>
                        <p class="mb-2 text-lg">{entry.data.company}</p>
                        <div class="text-sm">
                            <Content />
                        </div>
                        {entry.data.technologies.length > 0 && (
                            <ul role="list" class="mt-3 flex flex-wrap gap-2">
                                {entry.data.technologies.map((tech) => (
                                    <li class="soft-badge">{tech}</li>
                                ))}
                            </ul>
                        )}
                    </div>
                </li>
            ))
        }
        <li class="relative">
            <span class="timeline-node" aria-hidden="true">
                <Icon name="lucide:hourglass" class="size-6" />
            </span>
            <span class="sr-only">Start of career timeline</span>
        </li>
    </ol>
</section>
